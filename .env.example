# PDF Parse Application Environment Configuration
#
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control.

# ---------------------------------------------------------------------------
# Flask Security
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ---------------------------------------------------------------------------
# Tailscale / Remote Compute Node (MacBook)
# ---------------------------------------------------------------------------
# The Tailscale IP of your MacBook compute node
# Get it with: tailscale ip -4 (on the MacBook)
PDF_SERVICE_URL=http://100.x.x.x:8000
PDF_API_KEY=a-strong-random-secret-key

# Ollama LLM service URL
OLLAMA_URL=http://100.x.x.x:11434
OLLAMA_MODEL=qwen2.5:7b

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Path to SQLite database (default: /app/data/documents.db inside Docker)
DATABASE_PATH=/app/data/documents.db

# ---------------------------------------------------------------------------
# Linux-only fallback (legacy)
# ---------------------------------------------------------------------------
# If OLLAMA_URL is not set, falls back to OLLAMA_BASE_URL for backward compat
OLLAMA_BASE_URL=http://host.docker.internal:11434
